# Caminhos de dados (dentro do container). Sobrescreva se rodar fora do Docker.
DATA_DIR=/app/data
LAKEHOUSE_DIR=/app/lakehouse

# DuckDB: catalogo que expoe a camada gold para o dashboard
DUCKDB_PATH=/app/lakehouse/warehouse.duckdb

# Spark
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=2g
SPARK_APP_NAME=teste-big-core

# Regras de qualidade (limites de negocio)
# Bounding box do Brasil (lat/lon) para descartar coordenadas invalidas
BR_LAT_MIN=-34.0
BR_LAT_MAX=5.5
BR_LON_MIN=-74.0
BR_LON_MAX=-34.0
# Velocidade fisicamente plausivel para um caminhao (km/h)
VELOCIDADE_MAX_KMH=140

# Dashboard
DASHBOARD_PORT=8501
